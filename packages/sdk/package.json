{
  "name": "@shippie/sdk",
  "version": "2.0.0",
  "description": "Local-first SDK for Shippie tools: one-line local database, files, local AI, intents, install runtime, proof events, and secure backup.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./native": {
      "types": "./src/native/index.ts",
      "import": "./src/native/index.ts"
    },
    "./wrapper": {
      "types": "./src/wrapper/index.ts",
      "import": "./src/wrapper/index.ts"
    },
    "./data-standard": {
      "types": "./src/data-standard.ts",
      "import": "./src/data-standard.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./native": {
        "types": "./dist/native/index.d.ts",
        "import": "./dist/native/index.js"
      },
      "./wrapper": {
        "types": "./dist/wrapper/index.d.ts",
        "import": "./dist/wrapper/index.js"
      },
      "./data-standard": {
        "types": "./dist/data-standard.d.ts",
        "import": "./dist/data-standard.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "shippie",
    "pwa",
    "sdk",
    "local-first",
    "local-storage",
    "feedback",
    "proof",
    "offline",
    "privacy"
  ],
  "homepage": "https://shippie.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theprovider123/shippie.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/theprovider123/shippie/issues"
  },
  "scripts": {
    "typecheck": "tsc --noEmit && tsup --dts-only --silent",
    "lint": "echo 'lint placeholder'",
    "test": "bun test",
    "build": "tsup && node scripts/smoke-global-bundle.mjs",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@shippie/ambient": "workspace:*",
    "@shippie/backup-providers": "workspace:*",
    "@shippie/doc": "workspace:*",
    "@shippie/intelligence": "workspace:*",
    "@shippie/proximity": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "15",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "sideEffects": false
}
