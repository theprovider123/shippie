{
  "name": "@shippie/sdk",
  "version": "2.0.0",
  "description": "Same-origin client SDK for Shippie runtime apps. Auth, storage, files, feedback, analytics, install, native bridge. BYO backend (Supabase, Firebase).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "import": "./dist/native/index.js"
    },
    "./wrapper": {
      "types": "./dist/wrapper/index.d.ts",
      "import": "./dist/wrapper/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "shippie",
    "pwa",
    "sdk",
    "auth",
    "storage",
    "feedback",
    "analytics",
    "byo-backend",
    "supabase",
    "firebase"
  ],
  "homepage": "https://shippie.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shippie/shippie.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/shippie/shippie/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint placeholder'",
    "test": "bun test",
    "build": "tsup && node scripts/smoke-global-bundle.mjs",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@shippie/ambient": "workspace:*",
    "@shippie/backup-providers": "workspace:*",
    "@shippie/intelligence": "workspace:*",
    "@shippie/proximity": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "15",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "sideEffects": false
}
