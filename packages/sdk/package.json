{
  "name": "@shippie/sdk",
  "version": "0.0.1",
  "description": "Same-origin client SDK for Shippie runtime apps. Auth, storage, files, feedback, analytics, install, native bridge.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "import": "./dist/native/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint placeholder'",
    "test": "bun test",
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.5.1"
  },
  "keywords": ["shippie", "pwa", "sdk", "auth", "storage"],
  "sideEffects": false
}
