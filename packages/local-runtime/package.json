{
  "name": "@shippie/local-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "import": "./src/browser.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint placeholder'",
    "test": "bun test",
    "build": "tsup && bun run copy-assets",
    "copy-assets": "node scripts/copy-assets.mjs",
    "smoke:opfs": "bun run build && node scripts/smoke-opfs.mjs",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@shippie/local-db": "workspace:*",
    "@shippie/local-files": "workspace:*",
    "@shippie/local-runtime-contract": "workspace:*",
    "wa-sqlite": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "playwright": "^1.59.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
