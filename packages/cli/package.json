{
  "name": "@shippie/cli",
  "version": "0.0.2",
  "description": "Build and deploy private local Shippie tools from your terminal.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "shippie": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "shippie",
    "pwa",
    "deploy",
    "cli",
    "no-app-store",
    "local-first",
    "private-tools"
  ],
  "homepage": "https://shippie.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theprovider123/shippie.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/theprovider123/shippie/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --outDir dist",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@shippie/analyse": "workspace:*",
    "@shippie/app-package-contract": "workspace:*",
    "@shippie/core": "workspace:*",
    "@shippie/templates": "workspace:*",
    "commander": "^13.0.0",
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
