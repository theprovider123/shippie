{
  "name": "@shippie/juice",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared juice primitives for Shippie arcade games — WebAudio sample bank, rAF tween, canvas particle system, mute persistence. Pure browser, no DOM-framework dependency. The React helpers (Confetti, useTutorial) live in the optional `react` subpath.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.tsx",
      "import": "./src/react.tsx"
    },
    "./samples": {
      "types": "./src/samples.ts",
      "import": "./src/samples.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "echo 'lint placeholder'",
    "build": "echo 'no build — types-only'",
    "clean": "rm -rf .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^19.2.5"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "typescript": "^5.7.0"
  }
}
