{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Co-Pilot",
  "slug": "co-pilot",
  "description": "Separated co-parent schedules, meds, and handover notes.",
  "icon": "/icon.svg",
  "theme_color": "#4E7C9A",
  "background_color": "#EDF3F1",
  "visibility": "private",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "custody-event",
      "meds-logged",
      "handover-note"
    ],
    "consumes": []
  },
  "data_schemas": {
    "entries": {
      "id": "text primary key",
      "kind": "text not null",
      "note": "text",
      "created_at": "datetime"
    }
  },
  "curation": {
    "surface": "labs",
    "category": "health-fitness",
    "tier": "private-flagship"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-co-pilot",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true,
  "data_passport": {
    "family": "co-pilot",
    "schema": "co-pilot.v1"
  }
}
