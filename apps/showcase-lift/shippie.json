{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Lift",
  "slug": "lift",
  "description": "A private strength tracker for the minute between sets. Two taps to log. One line to see you're stronger.",
  "icon": "/icon.svg",
  "theme_color": "#1a1a1a",
  "background_color": "#1a1a1a",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "workout-started",
      "set-logged",
      "workout-completed",
      "pr-broken",
      "training-load-updated",
      "deload-recommended"
    ],
    "consumes": [
      "sleep-logged",
      "nutrition-logged",
      "protein-target-hit",
      "hydration-logged",
      "caffeine-logged",
      "cycle-logged",
      "body-metrics-logged"
    ]
  },
  "data_schemas": {
    "exercises": {
      "id": "text primary key",
      "name": "text not null",
      "muscle_group": "text not null",
      "lineage_id": "text",
      "variant_id": "text",
      "default_unit": "text not null",
      "notes": "text"
    },
    "workouts": {
      "id": "text primary key",
      "started_at": "text not null",
      "completed_at": "text",
      "template_id": "text",
      "source": "text not null",
      "notes": "text"
    },
    "sets": {
      "id": "text primary key",
      "step_id": "text not null",
      "set_index": "integer not null",
      "weight": "real not null",
      "reps": "integer not null",
      "unit": "text not null",
      "set_type": "text not null",
      "rpe": "real",
      "rir": "integer",
      "bar_weight": "real",
      "completed_at": "text not null",
      "source": "text not null"
    },
    "prs": {
      "id": "text primary key",
      "kind": "text not null",
      "variant_id": "text",
      "lineage_id": "text",
      "rep_range": "text",
      "weight": "real not null",
      "reps": "integer not null",
      "set_id": "text not null",
      "achieved_at": "text not null"
    }
  },
  "spaces": {
    "enabled": true,
    "roles": [
      {
        "id": "athlete",
        "permissions": [
          "read",
          "write",
          "invite"
        ]
      },
      {
        "id": "coach",
        "permissions": [
          "read"
        ]
      },
      {
        "id": "viewer",
        "permissions": [
          "read"
        ]
      }
    ],
    "syncMode": "sealed-cloud",
    "archivable": true
  },
  "curation": {
    "surface": "featured",
    "category": "health-fitness"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-lift",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true,
  "data_passport": {
    "family": "lift",
    "schema": "lift.v1"
  }
}
