{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Lift",
  "slug": "lift",
  "description": "A private strength tracker for the minute between sets. Two taps to log. One line to see you're stronger.",
  "icon": "/icon.svg",
  "theme_color": "#1a1a1a",
  "background_color": "#1a1a1a",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "workout-completed",
      "pr-broken",
      "set-logged"
    ]
  },
  "spaces": {
    "enabled": true,
    "roles": [
      {
        "id": "athlete",
        "permissions": [
          "read",
          "write",
          "invite"
        ]
      },
      {
        "id": "coach",
        "permissions": [
          "read"
        ]
      },
      {
        "id": "viewer",
        "permissions": [
          "read"
        ]
      }
    ],
    "syncMode": "sealed-cloud",
    "archivable": true
  },
  "curation": {
    "surface": "featured",
    "category": "health-fitness"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-lift",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true,
  "data_passport": {
    "family": "lift",
    "schema": "lift.v1"
  }
}
