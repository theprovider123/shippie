{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Shippie Match Room",
  "short_name": "Match Room",
  "slug": "match-room",
  "description": "Predictions, trivia, sweepstakes, votes, and matchday banter for the 2026 football tournament. No ads, no account.",
  "icon": "/icon.svg",
  "start_url": "/run/match-room/",
  "scope": "/run/match-room/",
  "theme_color": "#0E5C3A",
  "background_color": "#FAF7EF",
  "display": "standalone",
  "orientation": "portrait",
  "groups": {
    "enabled": true
  },
  "spaces": {
    "enabled": true,
    "roles": [
      {
        "id": "host",
        "permissions": [
          "read",
          "write",
          "invite",
          "moderate",
          "archive"
        ]
      },
      {
        "id": "play",
        "permissions": [
          "read",
          "write"
        ]
      },
      {
        "id": "display",
        "permissions": [
          "read"
        ]
      }
    ],
    "syncMode": "gossip",
    "archivable": true
  },
  "data": {
    "mode": "shippie-documents",
    "documents": [
      "room-archive"
    ],
    "attachments": false,
    "recovery": "inherited",
    "migrations": "snapshot-v0",
    "snapshots": "inherited",
    "media": "none",
    "realtime": "inherited",
    "localStorage": {
      "keys": [
        "match-room-theme"
      ],
      "prefixes": [
        "shippie.matchRoom."
      ]
    }
  },
  "intents": {
    "provides": [
      "matchday-prediction-stats",
      "tournament-leaderboard",
      "tournament-fixtures-2026",
      "city-of-the-day",
      "live-match-status"
    ],
    "consumes": [
      "user-display-name"
    ]
  },
  "data_schemas": {},
  "curation": {
    "surface": "featured",
    "category": "social"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-match-room",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
