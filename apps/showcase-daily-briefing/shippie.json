{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Daily Briefing",
  "slug": "daily-briefing",
  "description": "Morning rundown. Subscribes to the launch-slate intent graph and surfaces agent insights.",
  "icon": "/icon.svg",
  "theme_color": "#74A57F",
  "background_color": "#FAF7EF",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "consumes": [
      "cooked-meal",
      "cooking-now",
      "workout-completed",
      "run-planned",
      "sleep-logged",
      "coffee-brewed",
      "caffeine-logged",
      "mood-logged",
      "mindful-session",
      "hydration-logged",
      "dough-ready",
      "body-metrics-logged",
      "symptom-logged",
      "therapy-checkin",
      "cycle-logged",
      "household-note",
      "chore-done",
      "dinner-planned",
      "handover-note",
      "meds-logged",
      "custody-event",
      "story-shared",
      "story-draft",
      "focus-session",
      "needs-restocking",
      "dined-out",
      "trip-note",
      "place-pinned",
      "expense-logged",
      "budget-limit"
    ]
  },
  "data_schemas": {
    "events": {
      "id": "text primary key",
      "intent": "text",
      "label": "text",
      "received_at": "datetime"
    }
  }
}
