{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Meal Planner",
  "slug": "meal-planner",
  "description": "Plan a week of meals from saved recipes and pantry contents.",
  "icon": "/icon.svg",
  "theme_color": "#E8603C",
  "background_color": "#FAF7EF",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "shopping-list"
    ],
    "consumes": [
      "shopping-list",
      "pantry-inventory",
      "budget-limit",
      "cooked-meal"
    ]
  },
  "acceptsTransfer": {
    "kinds": [
      "recipe"
    ]
  },
  "data_schemas": {
    "plans": {
      "id": "text primary key",
      "day": "text not null",
      "slot": "text not null",
      "recipe_name": "text",
      "created_at": "datetime"
    }
  },
  "curation": {
    "surface": "archived",
    "category": "food-drink",
    "successor": "palate"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-meal-planner",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true,
  "data_passport": {
    "family": "meal-planner",
    "schema": "meal-planner.v1"
  }
}
