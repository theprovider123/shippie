{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Pantry Scanner",
  "slug": "pantry-scanner",
  "description": "Scan barcodes and identify pantry items with on-device vision.",
  "icon": "/icon.svg",
  "theme_color": "#74A57F",
  "background_color": "#FAF7EF",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "pantry-inventory",
      "pantry-low"
    ]
  },
  "permissions": [
    "camera"
  ],
  "data_schemas": {
    "items": {
      "id": "text primary key",
      "name": "text not null",
      "barcode": "text",
      "quantity": "integer",
      "unit": "text",
      "added_at": "datetime"
    }
  },
  "curation": {
    "surface": "archived",
    "category": "tools",
    "successor": "palate"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-pantry-scanner",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true,
  "data_passport": {
    "family": "pantry-scanner",
    "schema": "pantry-scanner.v1"
  }
}
