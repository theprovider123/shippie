{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Habit Tracker",
  "slug": "habit-tracker",
  "description": "Daily habits that auto-check when you complete activities in other Shippie apps.",
  "icon": "/icon.svg",
  "theme_color": "#5EA777",
  "background_color": "#FAF7EF",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "consumes": [
      "cooked-meal",
      "workout-completed"
    ]
  },
  "data_schemas": {
    "habits": {
      "id": "text primary key",
      "name": "text not null",
      "intent": "text",
      "created_at": "datetime"
    },
    "checks": {
      "id": "text primary key",
      "habit_id": "text not null",
      "checked_at": "datetime",
      "source": "text"
    }
  },
  "curation": {
    "surface": "archived",
    "category": "health-fitness",
    "successor": "chiwit"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-habit-tracker",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
