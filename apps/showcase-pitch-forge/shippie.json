{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Pitch Forge",
  "slug": "pitch-forge",
  "description": "Pitches stay on this phone. Grant proposals, RFP responses, sponsorship asks — drafted by AI in your browser, never your text uploaded.",
  "icon": "/icon.svg",
  "theme_color": "#17694D",
  "background_color": "#F5EFE4",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "pitch-drafted",
      "pitch-sent"
    ]
  },
  "data_schemas": {
    "pitches": {
      "id": "text primary key",
      "type": "text",
      "title": "text",
      "target": "text",
      "deadline": "text",
      "status": "text",
      "created_at": "datetime",
      "updated_at": "datetime"
    },
    "sections": {
      "id": "text primary key",
      "pitch_id": "text",
      "kind": "text",
      "title": "text",
      "body_md": "text",
      "order": "integer"
    },
    "briefs": {
      "id": "text primary key",
      "pitch_id": "text",
      "body": "text",
      "captured_at": "datetime"
    },
    "versions": {
      "id": "text primary key",
      "pitch_id": "text",
      "label": "text",
      "snapshot_json": "text",
      "created_at": "datetime"
    },
    "templates": {
      "id": "text primary key",
      "type": "text",
      "name": "text",
      "section_kinds_json": "text",
      "is_builtin": "integer"
    }
  },
  "curation": {
    "surface": "archived",
    "category": "creative"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-pitch-forge",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
