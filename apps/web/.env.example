# =====================================================================
# Shippie web — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# =====================================================================

# Database (Hetzner Postgres via Cloudflare Tunnel; local dev: any Postgres)
DATABASE_URL="postgres://shippie:shippie@localhost:5432/shippie_dev"

# Auth.js v5 — generate via `openssl rand -base64 32`
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# OAuth providers (filled in Week 1)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# Worker ↔ Platform shared secret (HMAC for /api/internal/* endpoints)
WORKER_PLATFORM_SECRET=""

# App session cookie key material (separate from AUTH_SECRET)
APP_SESSION_KEY_CURRENT=""
APP_SESSION_KEY_PREVIOUS=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_APPS="shippie-apps"
R2_BUCKET_PUBLIC="shippie-public"
R2_BUCKET_BUILDS="shippie-builds"

# Cloudflare Workers for Platforms (Functions)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
CFW4P_DISPATCH_NAMESPACE="shippie-functions"

# GitHub App — create at https://github.com/settings/apps/new
# See: docs/self-hosting.md § GitHub App
GITHUB_APP_ID=""                    # Client ID (Iv23...) or numeric App ID — both work
GITHUB_APP_SLUG=""                  # URL slug, e.g. "shippie-deploy" (from github.com/apps/<slug>)
GITHUB_APP_PRIVATE_KEY=""           # Base64-encoded .pem  |  base64 -i app.private-key.pem
GITHUB_APP_WEBHOOK_SECRET=""        # Shared secret        |  openssl rand -hex 32

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend (email)
RESEND_API_KEY=""
AUTH_EMAIL_FROM="Shippie <onboarding@resend.dev>"

# Vercel Sandbox (build runner)
VERCEL_SANDBOX_TOKEN=""

# OpenAI (auto-packaging — feature-flagged)
OPENAI_API_KEY=""

# Handoff — desktop→mobile PWA install
# RESEND_API_KEY is already set above; reused by the handoff dispatcher.
# Web Push (VAPID) — generate via `bunx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:ops@shippie.app"

# Internal cron auth — accepted by /api/internal/* cron endpoints.
# Vercel Cron sends CRON_SECRET automatically; SHIPPIE_INTERNAL_CRON_TOKEN
# is for self-host / curl. See apps/web/lib/internal/cron-auth.ts.
CRON_SECRET=""
SHIPPIE_INTERNAL_CRON_TOKEN=""

# Private apps / invite-grant cookie HMAC — shared with the Worker runtime.
# Generate via `openssl rand -hex 32`. Required in production; dev falls back
# to a well-known insecure value.
SHIPPIE_INVITE_SECRET=""

# Public apex host for {slug}.$host marketplace URLs. Defaults to shippie.app.
SHIPPIE_PUBLIC_HOST="shippie.app"
