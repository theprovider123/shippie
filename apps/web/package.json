{
  "name": "@shippie/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo --port 4100",
    "build": "node ./scripts/exclude-dev-routes.mjs && next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "clean": "rm -rf .next .turbo *.tsbuildinfo test-results playwright-report"
  },
  "dependencies": {
