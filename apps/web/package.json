    "@resvg/resvg-js": "^2.6.2",
    "@shippie/db": "workspace:*",
    "@shippie/dev-storage": "workspace:*",
    "@shippie/pwa-injector": "workspace:*",
    "@shippie/sdk": "workspace:*",
    "@shippie/session-crypto": "workspace:*",
    "@shippie/shared": "workspace:*",
    "adm-zip": "^0.5.17",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.0",
    "jose": "^6.2.2",
    "nanoid": "^5.1.7",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "15",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0"
  }
