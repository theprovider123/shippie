{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Sip Log",
  "slug": "sip-log",
  "description": "One-tap water, coffee, and tea logger. Daily targets + 7-day chart. Provides hydration-logged + caffeine-logged so Sleep Logger and Daily Briefing have something to correlate against.",
  "icon": "/icon.svg",
  "theme_color": "#5EA777",
  "background_color": "#14120F",
  "visibility": "public",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "hydration-logged",
      "caffeine-logged"
    ]
  },
  "data_schemas": {
    "sips": {
      "id": "text primary key",
      "kind": "text not null",
      "ml": "integer",
      "mg": "integer",
      "logged_at": "datetime"
    }
  },
  "curation": {
    "surface": "archived",
    "category": "health-fitness",
    "tier": "legacy",
    "successor": "mise"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-sip-log",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true,
  "data_passport": {
    "family": "sip-log",
    "schema": "sip-log.v1"
  }
}
