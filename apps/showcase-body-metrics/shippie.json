{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Body Metrics",
  "slug": "body-metrics",
  "description": "Weight + body photos. Photos never leave the device.",
  "icon": "/icon.png",
  "theme_color": "#74A57F",
  "background_color": "#FAF7EF",
  "display": "standalone",
  "orientation": "portrait",
  "permissions": [
    "camera"
  ],
  "intents": {
    "provides": [
      "body-metrics-logged"
    ]
  },
  "data_schemas": {
    "measurements": {
      "id": "text primary key",
      "date": "text not null",
      "weight_kg": "real",
      "body_fat_pct": "real",
      "photo_local_id": "text",
      "created_at": "datetime"
    }
  },
  "curation": {
    "surface": "archived",
    "category": "health-fitness"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-body-metrics",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
