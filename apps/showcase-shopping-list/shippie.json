{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Shopping List",
  "slug": "shopping-list",
  "description": "Live shopping list. Pulls from meal plan; shares over local mesh.",
  "icon": "/icon.svg",
  "theme_color": "#4E7C9A",
  "background_color": "#FAF7EF",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "needs-restocking"
    ],
    "consumes": [
      "shopping-list",
      "pantry-low"
    ]
  },
  "data_schemas": {
    "items": {
      "id": "text primary key",
      "name": "text not null",
      "checked": "boolean",
      "source": "text",
      "added_at": "datetime"
    }
  },
  "curation": {
    "surface": "archived",
    "category": "tools",
    "successor": "recipe"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-shopping-list",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
