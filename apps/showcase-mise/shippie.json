{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Mise",
  "slug": "mise",
  "description": "A fast, food-literate nutrition log. Recents, favorites, saved meals, free-text, rough portions, and copy-yesterday keep logging quick; neutral patterns (protein spread, hydration/caffeine timing, workout fueling, cycle-phase, meal regularity) make it useful. Imports cooked meals and meal plans from Palate. No red failure states, no shame copy.",
  "icon": "/icon.svg",
  "theme_color": "#6E4A6B",
  "background_color": "#F5EFE4",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "nutrition-logged",
      "meal-logged",
      "protein-target-hit",
      "hydration-logged",
      "caffeine-logged",
      "macro-target-updated"
    ],
    "consumes": [
      "cooked-meal",
      "meal-planned",
      "shopping-list",
      "pantry-inventory",
      "workout-completed",
      "cycle-logged",
      "body-metrics-logged",
      "mood-logged"
    ]
  },
  "data_schemas": {
    "entries": {
      "id": "text primary key",
      "food_id": "text",
      "name": "text not null",
      "slot": "text not null",
      "qty": "real",
      "grams": "real",
      "kcal": "real",
      "protein_g": "real",
      "carb_g": "real",
      "fat_g": "real",
      "fiber_g": "real",
      "sodium_mg": "real",
      "caffeine_mg": "real",
      "water_ml": "real",
      "logged_at": "datetime",
      "note": "text"
    },
    "foods": {
      "id": "text primary key",
      "name": "text not null",
      "brand": "text",
      "serving_label": "text",
      "serving_grams": "real",
      "favorite": "integer"
    },
    "meals": {
      "id": "text primary key",
      "name": "text not null",
      "favorite": "integer"
    },
    "goals": {
      "mode": "text not null",
      "bodyweight_kg": "real",
      "units": "text"
    }
  },
  "curation": {
    "surface": "featured",
    "category": "health-fitness"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-mise",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true,
  "data_passport": {
    "family": "mise",
    "schema": "mise.v1"
  }
}
