{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Breath",
  "slug": "breath",
  "description": "Box, 4-7-8, and Wim Hof breathing with a visual ring that grows and shrinks. No audio, just rhythm.",
  "icon": "/icon.svg",
  "theme_color": "#5E7B5C",
  "background_color": "#14120F",
  "display": "standalone",
  "orientation": "portrait",
  "permissions": [
    "wake-lock"
  ],
  "enhance": {
    "rules": {
      "wakelock": {
        "selector": "[data-shippie-wakelock]"
      }
    }
  },
  "intents": {
    "provides": [
      "mindful-session"
    ]
  },
  "data_schemas": {
    "sessions": {
      "id": "text primary key",
      "pattern": "text not null",
      "rounds": "integer",
      "duration_seconds": "integer",
      "completed_at": "datetime"
    }
  },
  "curation": {
    "surface": "archived",
    "category": "health-fitness",
    "successor": "chiwit"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-breath",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
