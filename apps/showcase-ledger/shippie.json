{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Ledger",
  "slug": "ledger",
  "description": "Private expense tracking + group split-the-bill in multiple currencies. No bank scraping, no accounts.",
  "icon": "/icon.svg",
  "theme_color": "#17694D",
  "background_color": "#151A17",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "expense-logged",
      "budget-limit"
    ],
    "consumes": [
      "dined-out",
      "shopping-list",
      "expense-logged"
    ]
  },
  "data_schemas": {
    "expenses": {
      "id": "text primary key",
      "kind": "text not null",
      "note": "text",
      "amount": "real",
      "created_at": "datetime"
    },
    "groups": {
      "id": "text primary key",
      "name": "text not null",
      "base_currency": "text not null",
      "members_json": "text not null",
      "created_at": "datetime"
    },
    "group_expenses": {
      "id": "text primary key",
      "group_id": "text not null",
      "paid_by_id": "text not null",
      "amount_cents": "integer not null",
      "currency": "text not null",
      "note": "text",
      "occurred_on": "text not null",
      "split_among_json": "text not null",
      "created_at": "datetime"
    }
  },
  "curation": {
    "surface": "featured",
    "category": "tools"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-ledger",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
