{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Coffee",
  "slug": "coffee",
  "description": "lot. — a local-first coffee companion: brew timer with a pour arc, a cellar that tracks freshness and your palate, and a knowledge graph of origins, varieties and processes. Provides coffee-brewed (consumed by sleep-logger, daily-briefing) and caffeine-logged (subsumes part of sip-log for V60 obsessives).",
  "icon": "/icon.svg",
  "theme_color": "#C4633A",
  "background_color": "#F4EFE3",
  "visibility": "public",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "coffee-brewed",
      "caffeine-logged"
    ]
  },
  "data_schemas": {
    "bags": {
      "id": "text primary key",
      "name": "text not null",
      "roaster_name": "text",
      "origin_country": "text",
      "variety": "text",
      "process": "text",
      "roast_level": "text",
      "roast_date": "text",
      "grams_remaining": "real",
      "status": "text",
      "world_node_slug": "text"
    },
    "brews": {
      "id": "text primary key",
      "bag_id": "text",
      "recipe_id": "text",
      "actual_dose": "real",
      "actual_yield": "real",
      "actual_time": "integer",
      "brewed_at": "datetime"
    },
    "cup_scores": {
      "id": "text primary key",
      "bag_id": "text",
      "brightness": "integer",
      "body": "integer",
      "sweetness": "integer",
      "complexity": "integer",
      "clean": "integer",
      "taste_notes": "text",
      "published": "integer"
    }
  },
  "curation": {
    "surface": "featured",
    "category": "food-drink",
    "tier": "supported"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-coffee",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true,
  "data_passport": {
    "family": "coffee",
    "schema": "coffee.v1"
  }
}
