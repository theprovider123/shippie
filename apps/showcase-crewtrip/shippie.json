{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Crewtrip",
  "slug": "crewtrip",
  "description": "Crewtrip turns a friends trip into a live party hub: itinerary, host broadcasts, votes, challenges, playlists, and memories owned by the host and the crew.",
  "icon": "/icon.svg",
  "theme_color": "#1a1d19",
  "background_color": "#1a1d19",
  "display": "standalone",
  "orientation": "any",
  "intents": {
    "provides": [
      "event-memory",
      "event-score",
      "event-plan"
    ],
    "consumes": [
      "trip-note",
      "place-pinned",
      "dined-out"
    ]
  },
  "spaces": {
    "enabled": true,
    "roles": [
      {
        "id": "host",
        "permissions": [
          "read",
          "write",
          "invite",
          "moderate"
        ]
      },
      {
        "id": "crew",
        "permissions": [
          "read",
          "write"
        ]
      },
      {
        "id": "viewer",
        "permissions": [
          "read"
        ]
      }
    ],
    "syncMode": "inherited",
    "archivable": true
  },
  "data": {
    "mode": "shippie-documents",
    "documents": [
      "trip-archive"
    ],
    "attachments": true,
    "recovery": "inherited",
    "migrations": "snapshot-v0",
    "snapshots": "inherited",
    "media": "encrypted-chunked",
    "realtime": "inherited",
    "localStorage": {
      "keys": [
        "shippie-crewtrip-v3",
        "shippie-crewtrip-v3-backups",
        "shippie-crewtrip-device-id"
      ],
      "prefixes": [
        "shippie-crewtrip-host-v1:",
        "shippie-crewtrip-player-v1:"
      ]
    }
  },
  "data_passport": {
    "family": "crewtrip",
    "schema": "crewtrip.v1"
  },
  "data_schemas": {
    "events": {
      "id": "text primary key",
      "name": "text not null",
      "location": "text",
      "description": "text",
      "host_note": "text",
      "cover_media_url": "text",
      "language": "text",
      "theme": "text",
      "created_at": "datetime"
    },
    "event_days": {
      "id": "text primary key",
      "event_id": "text not null",
      "label": "text not null",
      "date_label": "text"
    },
    "crew_groups": {
      "id": "text primary key",
      "event_id": "text not null",
      "name": "text not null",
      "color": "text",
      "emoji": "text",
      "image_url": "text"
    },
    "eventees": {
      "id": "text primary key",
      "event_id": "text not null",
      "display_name": "text not null",
      "group_id": "text",
      "team": "text",
      "avatar_url": "text",
      "score": "integer"
    },
    "itinerary_items": {
      "id": "text primary key",
      "event_id": "text not null",
      "day_id": "text",
      "group_id": "text",
      "title": "text not null",
      "place": "text",
      "starts_at": "datetime",
      "status": "text"
    },
    "polls": {
      "id": "text primary key",
      "event_id": "text not null",
      "question": "text not null",
      "is_open": "integer"
    },
    "score_events": {
      "id": "text primary key",
      "event_id": "text not null",
      "eventee_id": "text not null",
      "points": "integer not null",
      "reason": "text",
      "kind": "text",
      "day_id": "text",
      "group_id": "text"
    },
    "game_definitions": {
      "id": "text primary key",
      "event_id": "text not null",
      "title": "text not null",
      "kind": "text",
      "points": "integer not null",
      "day_id": "text",
      "group_id": "text",
      "status": "text"
    },
    "game_submissions": {
      "id": "text primary key",
      "event_id": "text not null",
      "game_id": "text not null",
      "eventee_id": "text not null",
      "group_id": "text",
      "caption": "text",
      "media_url": "text",
      "media_kind": "text",
      "cheer_count": "integer",
      "created_at": "datetime"
    },
    "memories": {
      "id": "text primary key",
      "event_id": "text not null",
      "author": "text",
      "body": "text not null",
      "kind": "text",
      "day_id": "text",
      "group_id": "text",
      "media_url": "text",
      "media_name": "text"
    },
    "crew_messages": {
      "id": "text primary key",
      "event_id": "text not null",
      "author_id": "text not null",
      "group_id": "text",
      "scope": "text not null",
      "body": "text not null",
      "created_at": "datetime"
    },
    "crew_pulses": {
      "id": "text primary key",
      "event_id": "text not null",
      "eventee_id": "text not null",
      "group_id": "text",
      "kind": "text not null",
      "label": "text not null",
      "created_at": "datetime"
    },
    "surprise_drops": {
      "id": "text primary key",
      "event_id": "text not null",
      "title": "text not null",
      "message": "text not null",
      "unlock_type": "text not null",
      "unlock_value": "text",
      "revealed_at": "datetime",
      "created_at": "datetime"
    },
    "soundtrack_slots": {
      "id": "text primary key",
      "event_id": "text not null",
      "day_id": "text",
      "title": "text not null",
      "dj": "text",
      "playlist_url": "text",
      "note": "text",
      "starts_at": "datetime",
      "status": "text"
    },
    "trip_wraps": {
      "id": "text primary key",
      "event_id": "text not null",
      "title": "text not null",
      "note": "text",
      "is_published": "integer",
      "created_at": "datetime"
    },
    "crew_requests": {
      "id": "text primary key",
      "event_id": "text not null",
      "eventee_id": "text not null",
      "body": "text not null",
      "status": "text",
      "created_at": "datetime"
    }
  },
  "curation": {
    "surface": "featured",
    "category": "social"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-crewtrip",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
