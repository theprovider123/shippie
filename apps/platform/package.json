{
  "name": "@shippie/platform",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prepare:showcases": "bun scripts/prepare-showcases.mjs",
    "build": "bun scripts/prepare-showcases.mjs && vite build && bun scripts/wrap-worker-with-scheduled.mjs",
    "preview": "wrangler dev",
    "deploy": "bun run build && bun scripts/upload-sdk-bundle.mjs && wrangler deploy",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-kit sync && tsc --noEmit",
    "lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply shippie-platform-d1 --remote",
    "db:migrate:local": "wrangler d1 migrations apply shippie-platform-d1 --local",
    "test": "vitest run"
  },
  "dependencies": {
    "@lucia-auth/adapter-sqlite": "^3.0.0",
    "@shippie/access": "workspace:*",
    "@shippie/agent": "workspace:*",
    "@shippie/analyse": "workspace:*",
    "@shippie/local-ai": "workspace:*",
    "@shippie/local-runtime-contract": "workspace:*",
    "@shippie/app-package-builder": "workspace:*",
    "@shippie/app-package-contract": "workspace:*",
    "@shippie/backup-providers": "workspace:*",
    "@shippie/container-bridge": "workspace:*",
    "@shippie/proximity": "workspace:*",
    "@shippie/sdk": "workspace:*",
    "@shippie/templates": "workspace:*",
    "@shippie/shared": "workspace:*",
    "arctic": "^2.0.0",
    "fflate": "^0.8.2",
    "drizzle-orm": "^0.38.0",
    "lucia": "^3.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@sveltejs/adapter-cloudflare": "^4.7.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.28.0",
    "postgres": "^3.4.9",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.85.0"
  }
}
