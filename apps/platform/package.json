{
  "name": "@shippie/platform",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prepare:showcases": "bun scripts/prepare-showcases.mjs",
    "prepare:generated": "bun scripts/prepare-showcases.mjs --generated-only",
    "audit:storage": "bun scripts/audit-showcase-storage.mjs",
    "audit:local-tools": "bun scripts/audit-local-tool-slate.mjs",
    "audit:mobile": "bun scripts/mobile-audit/route-inventory.mjs && bun scripts/mobile-audit/audit-static-rules.mjs && bun scripts/mobile-audit/audit-tokens.mjs && bun scripts/mobile-audit/audit-showcase-overflow.mjs",
    "audit:showcase-runtime": "bun scripts/prepare-showcases.mjs && bun scripts/mobile-audit/audit-showcase-runtime.mjs",
    "prepare:whitepaper": "bun scripts/prepare-whitepaper.mjs",
    "build": "bun scripts/prepare-showcases.mjs && bun scripts/scan-external-refs.mjs static/__shippie-run src/routes src/lib/components src/lib/styles && bun scripts/maker-labels-check.mjs && bun scripts/audit-showcase-storage.mjs && bun scripts/prepare-whitepaper.mjs && vite build && bun scripts/wrap-worker-with-scheduled.mjs",
    "preview": "wrangler dev",
    "deploy": "bun run build && bun scripts/upload-sdk-bundle.mjs && wrangler deploy",
    "deploy:verified": "bun run build && bun scripts/upload-sdk-bundle.mjs && wrangler deploy && bun scripts/prove-sealed-cloud.mjs --origin https://shippie.app --profiles quick",
    "smoke:private-spaces": "bun scripts/smoke-private-spaces.mjs",
    "check:sealed-cloud": "bun scripts/check-sealed-cloud.mjs",
    "check:migrations": "bun scripts/check-migrations.mjs",
    "bench:sealed-cloud": "bun scripts/bench-sealed-cloud.mjs",
    "torture:sealed-cloud": "bun scripts/torture-sealed-cloud.mjs",
    "prove:sealed-cloud": "bun scripts/prove-sealed-cloud.mjs",
    "prove:offline-root": "bun scripts/prove-offline-root.mjs",
    "prove:offline-conformance": "bun scripts/prove-offline-conformance.mjs",
    "prove:offline-webkit": "ENGINE=webkit bun scripts/prove-offline-conformance.mjs",
    "prove:offline-origin-killed": "ORIGIN_KILLED=1 bun scripts/prove-offline-conformance.mjs",
    "prove:offline-webkit-origin-killed": "ENGINE=webkit ORIGIN_KILLED=1 bun scripts/prove-offline-conformance.mjs",
    "prove:local-data": "bun scripts/prove-local-data-contract.mjs",
    "prove:device-handover": "bun scripts/prove-device-handover.mjs",
    "check": "bun run check:migrations && bun run prepare:generated && bun scripts/prepare-whitepaper.mjs && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "bun run prepare:generated && svelte-kit sync && tsc --noEmit",
    "lint": "bun run prepare:generated && bun scripts/prepare-whitepaper.mjs && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply shippie-platform-d1 --remote",
    "db:migrate:local": "wrangler d1 migrations apply shippie-platform-d1 --local",
    "test": "bun run prepare:generated && vitest run"
  },
  "dependencies": {
    "@lucia-auth/adapter-sqlite": "^3.0.0",
    "@shippie/access": "workspace:*",
    "@shippie/agent": "workspace:*",
    "@shippie/analyse": "workspace:*",
    "@shippie/local-ai": "workspace:*",
    "@shippie/local-runtime-contract": "workspace:*",
    "@shippie/app-package-builder": "workspace:*",
    "@shippie/app-package-contract": "workspace:*",
    "@shippie/backup-providers": "workspace:*",
    "@shippie/container-bridge": "workspace:*",
    "@shippie/design-tokens": "workspace:*",
    "@shippie/doc": "workspace:*",
    "@shippie/intents": "workspace:*",
    "@shippie/offline-capsule": "workspace:*",
    "@shippie/proximity": "workspace:*",
    "@shippie/qr": "workspace:*",
    "@shippie/sdk": "workspace:*",
    "@shippie/share": "workspace:*",
    "@shippie/templates": "workspace:*",
    "@shippie/shared": "workspace:*",
    "@shippie/spaces": "workspace:*",
    "@shippie/trust-ledger": "workspace:*",
    "arctic": "^2.0.0",
    "fflate": "^0.8.2",
    "drizzle-orm": "^0.38.0",
    "lucia": "^3.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-cloudflare": "^4.7.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.28.0",
    "fake-indexeddb": "^6.0.0",
    "marked": "^18.0.2",
    "playwright": "^1.60.0",
    "postgres": "^3.4.9",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.85.0"
  }
}
