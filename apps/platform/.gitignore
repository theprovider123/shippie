.svelte-kit
.wrangler
.env
.env.*
!.env.example
node_modules
build
dist

# Build output from `bun scripts/prepare-showcases.mjs` (regenerated
# every `bun run build`; copying showcase dist files here is a build
# step, not source).
static/run/
static/brand-preview/
static/__shippie-pwa/shell-assets.json

# Build output from `bun scripts/prepare-whitepaper.mjs` (regenerated
# every `bun run build`; the .md at docs/WHITEPAPER.md is the source
# of truth). The showcase catalog is committed because hooks, tests,
# and the service worker import it before the build step runs.
src/lib/_generated/*
!src/lib/_generated/showcase-catalog.ts
!src/lib/_generated/precache-list.ts
