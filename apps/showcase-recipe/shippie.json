{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Palate",
  "slug": "palate",
  "description": "Recipes, cooking mode, meal planning, pantry, and shopping in one local-first kitchen app.",
  "icon": "/icon-512.png",
  "theme_color": "#D86918",
  "background_color": "#F4E4C1",
  "display": "standalone",
  "orientation": "portrait",
  "ai": [],
  "intents": {
    "provides": [
      "cooked-meal",
      "cooking-now",
      "shopping-list",
      "needs-restocking",
      "pantry-inventory",
      "pantry-low",
      "meal-planned"
    ],
    "consumes": [
      "pantry-inventory",
      "shopping-list",
      "pantry-low",
      "budget-limit",
      "cooked-meal",
      "mood-logged",
      "hydration-logged"
    ]
  },
  "acceptsTransfer": {
    "kinds": [
      "recipe"
    ]
  },
  "enhance": {
    "rules": {
      "wakelock": {
        "selector": "[data-shippie-wakelock]"
      },
      "list-swipe": {
        "selector": ".shopping-list",
        "haptic": "tap"
      },
      "text-autocomplete": {
        "selector": "input[autocomplete=\"shippie\"]",
        "source": "local-db"
      }
    }
  },
  "permissions": [
    "camera",
    "wake-lock"
  ],
  "data": {
    "mode": "shippie-documents",
    "documents": [
      "recipe-book"
    ],
    "attachments": false,
    "recovery": "inherited",
    "migrations": "snapshot-v0",
    "snapshots": "inherited",
    "media": "none",
    "realtime": "inherited",
    "localStorage": {
      "keys": [
        "shippie.palate.recipe-hub.v1",
        "shippie.palate.recent-searches.v1",
        "shippie.palate.aisle-order.v1",
        "shippie.palate.last-tab.v1",
        "shippie.meal-planner.v2",
        "shippie.shopping-list.v1",
        "shippie.pantry-scanner.v1"
      ],
      "prefixes": [
        "shippie.shopping-list."
      ]
    }
  },
  "data_passport": {
    "family": "palate",
    "schema": "palate.v1"
  },
  "data_schemas": {
    "recipes": {
      "id": "text primary key",
      "title": "text not null",
      "description": "text",
      "category": "text",
      "cuisine": "text",
      "servings": "integer",
      "prep_time": "integer",
      "cook_time": "integer",
      "created_at": "datetime",
      "updated_at": "datetime"
    },
    "meal_plan": {
      "id": "text primary key",
      "date": "text not null",
      "meal_type": "text not null",
      "recipe_id": "text not null",
      "servings": "integer"
    },
    "pantry": {
      "id": "text primary key",
      "name": "text not null",
      "quantity": "real",
      "unit": "text",
      "location": "text"
    },
    "shopping_items": {
      "id": "text primary key",
      "name": "text not null",
      "checked": "integer",
      "source": "text"
    }
  },
  "curation": {
    "surface": "featured",
    "category": "food-drink"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-recipe",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
