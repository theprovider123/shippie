{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Recipe",
  "slug": "recipe",
  "description": "A local-first kitchen app for recipes, meal planning, shopping, and pantry notes.",
  "icon": "/icon.png",
  "theme_color": "#E8603C",
  "background_color": "#FAF7EF",
  "display": "standalone",
  "orientation": "portrait",
  "ai": [],
  "intents": {
    "provides": [
      "cooked-meal",
      "cooking-now",
      "shopping-list",
      "needs-restocking",
      "pantry-inventory",
      "pantry-low"
    ],
    "consumes": [
      "pantry-inventory",
      "shopping-list",
      "pantry-low",
      "budget-limit",
      "cooked-meal"
    ]
  },
  "acceptsTransfer": {
    "kinds": [
      "recipe"
    ]
  },
  "spaces": {
    "enabled": true,
    "roles": [
      {
        "id": "owner",
        "permissions": [
          "read",
          "write",
          "invite"
        ]
      },
      {
        "id": "editor",
        "permissions": [
          "read",
          "write"
        ]
      },
      {
        "id": "viewer",
        "permissions": [
          "read"
        ]
      }
    ],
    "syncMode": "sealed-cloud",
    "archivable": true
  },
  "enhance": {
    "rules": {
      "wakelock": {
        "selector": "video[data-shippie-canvas], canvas[data-shippie-canvas]"
      },
      "list-swipe": {
        "selector": "ul[data-shippie-list]",
        "haptic": "tap"
      },
      "text-autocomplete": {
        "selector": "input[autocomplete=\"shippie\"]",
        "source": "local-db"
      }
    }
  },
  "permissions": [
    "camera",
    "wake-lock"
  ],
  "data": {
    "mode": "shippie-documents",
    "documents": [
      "recipe-book"
    ],
    "attachments": false,
    "recovery": "inherited",
    "migrations": "snapshot-v0",
    "snapshots": "inherited",
    "media": "none",
    "realtime": "inherited",
    "localStorage": {
      "keys": [
        "shippie:recipe-saver:backup-meta:v1",
        "shippie:recipe-saver:safety-prompts:v1",
        "shippie:recipe-saver:persistence:v1",
        "shippie.meal-planner.v2",
        "shippie.shopping-list.v1",
        "shippie.pantry-scanner.v1",
        "shippie.pantry-scanner.consumption.v1",
        "shippie.pantry-scanner.off-cache.v1"
      ],
      "prefixes": [
        "shippie.shopping-list."
      ]
    }
  },
  "data_schemas": {
    "recipes": {
      "id": "text primary key",
      "title": "text not null",
      "notes": "text",
      "created_at": "datetime",
      "updated_at": "datetime"
    },
    "ingredients": {
      "id": "text primary key",
      "recipe_id": "text not null",
      "name": "text not null",
      "amount": "text",
      "unit": "text",
      "barcode": "text",
      "brand": "text"
    }
  },
  "curation": {
    "surface": "featured",
    "category": "food-drink"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-recipe",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
