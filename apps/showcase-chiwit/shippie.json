{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Chiwit",
  "slug": "chiwit",
  "description": "A wholesome personal tracker. Five mood words, the little things, a garden of your days — local, kind, yours.",
  "icon": "/icon-512.png",
  "theme_color": "#A84136",
  "background_color": "#F7F4EF",
  "visibility": "public",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "mood-logged",
      "sleep-logged",
      "hydration-logged",
      "workout-completed",
      "mindful-session",
      "symptom-logged",
      "body-metrics-logged"
    ],
    "consumes": [
      "cooked-meal",
      "caffeine-logged",
      "coffee-brewed",
      "brewed-tea",
      "wellness-ritual"
    ]
  },
  "enhance": {
    "rules": {
      "wakelock": {
        "selector": "[data-shippie-wakelock]"
      }
    }
  },
  "permissions": [
    "wake-lock"
  ],
  "data": {
    "mode": "shippie-documents",
    "documents": [
      "garden"
    ],
    "attachments": false,
    "recovery": "inherited",
    "migrations": "snapshot-v0",
    "snapshots": "inherited",
    "media": "none",
    "realtime": "inherited",
    "localStorage": {
      "keys": [
        "shippie.chiwit.garden.v1",
        "shippie.chiwit.daily-pulse.v1"
      ],
      "prefixes": [
        "shippie.chiwit."
      ]
    }
  },
  "data_passport": {
    "family": "chiwit",
    "schema": "chiwit.v1"
  },
  "data_schemas": {
    "days": {
      "date": "text primary key",
      "mood": "text",
      "things": "text",
      "journal": "text",
      "intention": "text"
    },
    "letters": {
      "id": "text primary key",
      "week_ending": "text not null",
      "body": "text",
      "pills": "text",
      "arc": "text"
    },
    "ambient": {
      "kind": "text not null",
      "source_app": "text",
      "at": "integer not null",
      "payload": "text"
    }
  },
  "curation": {
    "surface": "featured",
    "category": "health-fitness",
    "tier": "public-flagship"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-chiwit",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true
}
