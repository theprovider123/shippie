{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Receipt Snap",
  "slug": "receipt-snap",
  "description": "Snap a receipt — extract vendor, total, items on this phone. Photos never leave the device.",
  "icon": "/icon.svg",
  "theme_color": "#5EA777",
  "background_color": "#F5EFE4",
  "visibility": "public",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "expense-logged",
      "dined-out",
      "place.snapped"
    ]
  },
  "data_schemas": {
    "receipts": {
      "id": "text primary key",
      "vendor": "text",
      "total_cents": "integer",
      "currency": "text",
      "category": "text",
      "occurred_on": "text",
      "captured_at": "datetime",
      "raw_ocr_text": "text",
      "image_data_url": "text",
      "note": "text"
    }
  },
  "curation": {
    "surface": "featured",
    "category": "tools",
    "tier": "public-flagship"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-receipt-snap",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true,
  "data_passport": {
    "family": "receipt-snap",
    "schema": "receipt-snap.v1"
  }
}
