{
  "$schema": "https://shippie.app/schemas/app.json",
  "name": "Symptom Diary",
  "slug": "symptom-diary",
  "description": "Chronic illness symptoms, triggers, medications, and exportable history.",
  "icon": "/icon.svg",
  "theme_color": "#74A57F",
  "background_color": "#FAF7EF",
  "display": "standalone",
  "orientation": "portrait",
  "intents": {
    "provides": [
      "symptom-logged",
      "med-taken"
    ],
    "consumes": [
      "sleep-logged",
      "mood-logged",
      "cooked-meal",
      "body-metrics-logged"
    ]
  },
  "data_schemas": {
    "symptoms": {
      "id": "text primary key",
      "kind": "text not null",
      "note": "text",
      "created_at": "datetime"
    }
  },
  "curation": {
    "surface": "featured",
    "category": "health-fitness"
  },
  "source_repo": "https://github.com/theprovider123/shippie/tree/main/apps/showcase-symptom-diary",
  "license": "AGPL-3.0-or-later",
  "remix_allowed": true,
  "data_passport": {
    "family": "symptom-diary",
    "schema": "symptom-diary.v1"
  }
}
